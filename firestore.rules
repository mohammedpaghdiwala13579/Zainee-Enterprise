rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write access to the Zainee collection (anonymous/public)
    match /zainee_documents/{documentId} {
      allow read, write: if true;
    }

    // Allow read/write access to the Comilla collection (anonymous/public)
    match /comilla_documents/{documentId} {
      allow read, write: if true;
    }

    // Allow read/write access to the legacy documents collection
    match /documents/{documentId} {
      allow read, write: if true;
    }
  }
}
